<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:expanded="true"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            app:title="@string/nav_discover" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="96dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- API-key warning banner -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/banner_no_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorErrorContainer"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:text="@string/search_api_key_missing"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnErrorContainer" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Trending -->
                <TextView
                    style="@style/Discover.SectionTitle"
                    android:text="@string/section_trending" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/trending_progress"
                    style="@style/Widget.Material3.LinearProgressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/trending_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_discover_poster" />

                <!-- Popular -->
                <TextView
                    style="@style/Discover.SectionTitle"
                    android:text="@string/section_popular" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/popular_progress"
                    style="@style/Widget.Material3.LinearProgressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/popular_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_discover_poster" />

                <!-- Top on streaming -->
                <TextView
                    style="@style/Discover.SectionTitle"
                    android:text="@string/section_streaming_top" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingHorizontal="12dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/service_chips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_netflix"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Netflix"
                            android:tag="netflix" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prime"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prime"
                            android:tag="prime" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_disney"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disney+"
                            android:tag="disney" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_apple"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Apple TV"
                            android:tag="apple" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_crunchyroll"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crunchyroll"
                            android:tag="crunchyroll" />
                    </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/streaming_progress"
                    style="@style/Widget.Material3.LinearProgressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/streaming_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_discover_poster" />

                <!-- Recently added -->
                <TextView
                    style="@style/Discover.SectionTitle"
                    android:text="@string/section_recent" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/recent_progress"
                    style="@style/Widget.Material3.LinearProgressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recent_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_discover_poster" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
