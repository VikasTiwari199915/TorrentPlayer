<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0820">

    <!-- Full-bleed backdrop behind everything. Hidden when the user disables
         backdrops in Settings (or when no backdrop URL is available). -->
    <ImageView
        android:id="@+id/backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:visibility="gone"
        tools:src="@drawable/banner"
        tools:visibility="visible" />

    <!-- Readability scrim, only shown together with the backdrop. -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/tv_backdrop_scrim"
        android:visibility="gone"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="48dp">

        <ImageView
            android:id="@+id/poster"
            android:layout_width="280dp"
            android:layout_height="420dp"
            android:scaleType="centerCrop"
            android:background="#222"
            android:contentDescription="@null"
            tools:src="@drawable/banner" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="32dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6"
                tools:text="The Boys" />

            <TextView
                android:id="@+id/meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#DDDDDD"
                android:textSize="16sp"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6"
                tools:text="Show · 2019 · Action, Comedy · 8.5★" />

            <TextView
                android:id="@+id/overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#EEEEEE"
                android:textSize="14sp"
                android:maxLines="6"
                android:ellipsize="end"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="6"
                tools:text="A group of vigilantes…" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Available torrents"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/torrents"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:descendantFocusability="afterDescendants"
                tools:itemCount="3"
                tools:listitem="@layout/item_tv_torrent" />

            <TextView
                android:id="@+id/empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#888"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="No torrents found" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
